# Copy this file to .env and fill in your own values.
# Never commit your real .env file.

PORT=4000

# Any long random string works. You can generate one at https://www.random.org/strings/
JWT_SECRET=change_this_to_a_long_random_string
SESSION_SECRET=change_this_to_a_different_long_random_string

# --- Google Sign-In (optional but supported) ---
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a project (or use an existing one)
# 3. Configure the OAuth consent screen (External, add your school email as a test user)
# 4. Create OAuth Client ID -> Web application
# 5. Add this Authorized redirect URI: http://localhost:4000/api/auth/google/callback
# 6. Paste the Client ID and Client Secret below
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Where the frontend lives, used to redirect back after Google login
CLIENT_URL=http://localhost:4000
